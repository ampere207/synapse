# Environment template for Synapse
# Copy this to .env and fill in your values

# Database (for Docker, use postgres:5432; for local, use localhost:5432)
DATABASE_URL=postgresql://synapse:synapse@postgres:5432/synapse

# Redis (for Docker, use redis:6379; for local, use localhost:6379)
REDIS_URL=redis://redis:6379/0

# Qdrant Vector Database
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=synapse-key

# JWT & Security
SECRET_KEY=dev-secret-key-change-in-production-to-strong-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI - Gemini API
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Speech-to-Text Provider
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# Supabase (File Storage)
SUPABASE_URL=
SUPABASE_KEY=

# Frontend URLs (for Docker, use http://localhost; for local development, adjust as needed)
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Development/Debug
DEBUG=True

# Batch Processing Configuration
TRANSCRIPT_BATCH_WINDOW_SECONDS=120
TRANSCRIPT_BATCH_TOKEN_LIMIT=1000
